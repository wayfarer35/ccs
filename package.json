{
  "name": "@wayfarer35/ccs",
  "version": "0.2.4",
  "description": "Claude Code Switch — 在多套供应商配置间切换并启动 Claude Code",
  "type": "module",
  "bin": {
    "ccs": "dist/cli.js"
  },
  "files": [
    "dist",
    "scripts/postinstall.mjs",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "release": "standard-version -- --release-as patch",
    "release-major": "standard-version -- --release-as major",
    "release-minor": "standard-version -- --release-as minor",
    "postinstall": "node scripts/postinstall.mjs"
  },
  "dependencies": {
    "ink": "^5.2.1",
    "react": "^18.3.1"
  },
  "keywords": [
    "claude-code",
    "cli",
    "config",
    "provider",
    "switch"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@vitest/coverage-v8": "^4.1.9",
    "standard-version": "^9.5.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
